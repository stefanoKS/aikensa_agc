}
QPushButton {
    background-color: #59627f;
    color: #f7f2ff;
    border: 1px solid #929cc0;
    border-radius: 8px;
    padding: 6px 10px;
}
QPushButton:hover {
    background-color: #6a7393;
}
QPushButton#InspectButton,
QPushButton#InspectTapeButton {
    background-color: #9ed8c3;
    border: 1px solid #c7efe1;
    color: #23353a;
}
QPushButton#counterReset {
    background-color: #cab8f2;
    border: 1px solid #e2d6ff;
    color: #3c3654;
}
QLineEdit,
QComboBox {
    background-color: #25293d;
    color: #f3efff;
    border: 1px solid #7f89a8;
    border-radius: 6px;
    padding: 4px 8px;
}
QRadioButton {
    color: #e4ddf6;
}
QRadioButton::indicator {
    width: 14px;
    height: 14px;
}
QRadioButton::indicator:unchecked {
    background-color: #25293d;
    border: 1px solid #9aa3bf;
    border-radius: 7px;
}
QRadioButton::indicator:checked {
    background-color: #f0a9c5;
    border: 1px solid #f0a9c5;
    border-radius: 7px;
}
QFrame#line_1,
QFrame#line_2,
QFrame#line_3,
QFrame#line_4,
QFrame#line_5,
QFrame#line_6,
QFrame#line_7 {
    color: #8089aa;
