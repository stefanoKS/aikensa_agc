}
QLabel#label_20,
QLabel#JIKAN_ATARI,
QLabel#status_SERIALNO,
QLabel#status_LOTNO {
    color: #ffd7b8;
}
QLabel#current_kansei,
QLabel#status_kansei {
    color: #dff7e7;
    background-color: #365045;
    border: 1px solid #9ed8b5;
    border-radius: 6px;
}
QLabel#current_furyou,
QLabel#status_furyou {
